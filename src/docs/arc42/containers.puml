@startuml
!include <C4/C4_Container>

Person(developer, "Developer", "Developer using the Bausteinsicht CLI to manage architecture models")
System_Ext(drawio_app, "draw.io App", "draw.io desktop or web application for visual diagram editing")
System_Ext(ide, "IDE", "IDE with JSON Schema support for JSONC editing with autocompletion")
System_Boundary(bausteinsicht, "Bausteinsicht") {
  Container(bausteinsicht_changelog, "Changelog", "Go", "Architecture changelog generation between two git refs")
  Container(bausteinsicht_cli, "CLI", "Go / Cobra", "Command-line interface providing validate, sync, export, and watch commands")
  Container(bausteinsicht_constraints, "Constraints", "Go", "Validation constraints for model linting and consistency checking")
  Container(bausteinsicht_diagram, "Diagram", "Go", "Text-based diagram export to Mermaid C4 and PlantUML formats with markdown wrapping")
  Container(bausteinsicht_diff, "Diff", "Go", "As-is vs. to-be architecture comparison")
  Container(bausteinsicht_drawio, "draw.io", "Go / etree", "draw.io XML document handling — elements, connectors, templates, and labels")
  Container(bausteinsicht_export, "Export", "Go", "Export diagrams to PNG, SVG, and other visual formats via draw.io CLI")
  Container(bausteinsicht_exporter, "Exporter", "Go", "Architecture export to Structurizr DSL and other formats")
  Container(bausteinsicht_graph, "Graph", "Go", "Relationship graph analysis — cycle detection and dependency depth")
  Container(bausteinsicht_health, "Health", "Go", "Architecture health scoring — completeness, conformance, and complexity")
  Container(bausteinsicht_importer, "Importer", "Go", "Import architecture from Structurizr DSL and LikeC4 formats")
  Container(bausteinsicht_layout, "Layout", "Go", "Auto-layout algorithms for positioning elements in draw.io diagrams")
  Container(bausteinsicht_lsp, "Language Server", "Go", "Language Server Protocol implementation for VS Code and other editors")
  Container(bausteinsicht_model, "Model", "Go", "JSONC architecture model management — loading, validation, and mutation")
  Container(bausteinsicht_overlay, "Overlay", "Go", "Metric heatmap overlay application and removal on draw.io diagrams")
  Container(bausteinsicht_schema, "Schema", "Go", "JSON Schema generation from Go model types for IDE autocompletion")
  Container(bausteinsicht_search, "Search", "Go", "Element and relationship search with filtering and pattern matching")
  Container(bausteinsicht_snapshot, "Snapshot", "Go", "Versioned architecture snapshot storage and restore")
  Container(bausteinsicht_stale, "Stale", "Go", "Detects unused or forgotten architecture elements via git history and ADR/status metadata")
  Container(bausteinsicht_sync, "Sync Engine", "Go", "Bidirectional synchronization engine between JSONC model and draw.io diagrams")
  Container(bausteinsicht_table, "Table", "Go", "Export architecture to CSV and Markdown table formats")
  Container(bausteinsicht_template, "Template", "Go", "draw.io template generation from element specification (shapes, layout)")
  Container(bausteinsicht_watcher, "Watcher", "Go / fsnotify", "File system monitoring for automatic sync on model or diagram changes")
  Container(bausteinsicht_workspace, "Workspace", "Go", "Multi-model workspace configuration loading and merging")
}

Rel(developer, bausteinsicht_cli, "runs commands")
Rel(developer, ide, "edits JSONC")
Rel(developer, drawio_app, "edits diagrams")
Rel(ide, bausteinsicht_model, "JSON Schema validation")
Rel(drawio_app, bausteinsicht_drawio, "modifies .drawio file")
Rel(bausteinsicht_cli, bausteinsicht_model, "loads/saves JSONC")
Rel(bausteinsicht_cli, bausteinsicht_sync, "triggers sync")
Rel(bausteinsicht_cli, bausteinsicht_watcher, "starts watch mode")
Rel(bausteinsicht_cli, bausteinsicht_diagram, "exports Mermaid diagrams")
Rel(bausteinsicht_cli, bausteinsicht_export, "triggers export")
Rel(bausteinsicht_cli, bausteinsicht_importer, "imports models")
Rel(bausteinsicht_cli, bausteinsicht_exporter, "exports DSL")
Rel(bausteinsicht_cli, bausteinsicht_table, "exports tables")
Rel(bausteinsicht_cli, bausteinsicht_search, "searches elements")
Rel(bausteinsicht_cli, bausteinsicht_constraints, "validates constraints")
Rel(bausteinsicht_cli, bausteinsicht_lsp, "starts language server")
Rel(bausteinsicht_cli, bausteinsicht_changelog, "triggers changelog generation")
Rel(bausteinsicht_cli, bausteinsicht_diff, "triggers as-is/to-be diff")
Rel(bausteinsicht_cli, bausteinsicht_graph, "triggers graph analysis")
Rel(bausteinsicht_cli, bausteinsicht_health, "triggers health scoring")
Rel(bausteinsicht_cli, bausteinsicht_layout, "triggers auto-layout")
Rel(bausteinsicht_cli, bausteinsicht_overlay, "triggers overlay apply/remove")
Rel(bausteinsicht_cli, bausteinsicht_schema, "triggers schema generation")
Rel(bausteinsicht_cli, bausteinsicht_snapshot, "manages snapshots")
Rel(bausteinsicht_cli, bausteinsicht_stale, "triggers stale-element detection")
Rel(bausteinsicht_cli, bausteinsicht_template, "generates draw.io templates")
Rel(bausteinsicht_cli, bausteinsicht_workspace, "loads/merges workspace config")
Rel(bausteinsicht_sync, bausteinsicht_drawio, "creates/updates elements")
Rel(bausteinsicht_sync, bausteinsicht_model, "comment-preserving updates")
Rel(bausteinsicht_watcher, bausteinsicht_sync, "triggers on file change")
Rel(bausteinsicht_export, bausteinsicht_drawio, "reads diagram pages")
Rel(bausteinsicht_diagram, bausteinsicht_model, "reads model for export")
Rel(bausteinsicht_importer, bausteinsicht_model, "populates model")
Rel(bausteinsicht_exporter, bausteinsicht_model, "reads model")
Rel(bausteinsicht_search, bausteinsicht_model, "searches elements")
Rel(bausteinsicht_table, bausteinsicht_model, "reads model")
Rel(bausteinsicht_table, bausteinsicht_diagram, "optionally uses diagrams")
Rel(bausteinsicht_constraints, bausteinsicht_model, "validates model")
Rel(bausteinsicht_lsp, bausteinsicht_model, "indexes for completion")
Rel(bausteinsicht_changelog, bausteinsicht_diff, "computes as-is/to-be delta per ref")
Rel(bausteinsicht_changelog, bausteinsicht_model, "loads model at each git ref")
Rel(bausteinsicht_diff, bausteinsicht_model, "reads as-is/to-be sections")
Rel(bausteinsicht_graph, bausteinsicht_model, "reads elements and relationships")
Rel(bausteinsicht_health, bausteinsicht_model, "reads elements for scoring")
Rel(bausteinsicht_layout, bausteinsicht_drawio, "writes computed positions")
Rel(bausteinsicht_layout, bausteinsicht_model, "reads element hierarchy")
Rel(bausteinsicht_schema, bausteinsicht_model, "reflects Go struct types")
Rel(bausteinsicht_snapshot, bausteinsicht_model, "serializes/restores model state")
Rel(bausteinsicht_stale, bausteinsicht_drawio, "reads/writes risk-color marking")
Rel(bausteinsicht_stale, bausteinsicht_model, "reads status/ADR metadata")
Rel(bausteinsicht_stale, bausteinsicht_overlay, "reuses heatmap color scale")
Rel(bausteinsicht_template, bausteinsicht_drawio, "generates template shapes/styles")
Rel(bausteinsicht_template, bausteinsicht_model, "reads element kind specification")
Rel(bausteinsicht_workspace, bausteinsicht_model, "merges multiple models")
@enduml
