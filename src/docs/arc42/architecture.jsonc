{
  "$schema": "https://raw.githubusercontent.com/docToolchain/Bausteinsicht/main/schema/bausteinsicht.schema.json",
  "config": {
    "author": "Bausteinsicht contributors",
    "repo": "github.com/docToolchain/Bauteinsicht"
  },
  "specification": {
    "elements": {
      "actor": {
        "notation": "Actor",
        "description": "A person or external tool that interacts with the system"
      },
      "component": {
        "notation": "Component",
        "description": "A Go package within a container",
        "container": true
      },
      "container": {
        "notation": "Container",
        "description": "A Go package group within the system",
        "container": true
      },
      "external_system": {
        "notation": "External System",
        "description": "An external tool or application outside the system boundary"
      },
      "system": {
        "notation": "Software System",
        "description": "The Bausteinsicht system boundary",
        "container": true
      }
    },
    "relationships": {
      "triggers": {
        "notation": "triggers",
        "dashed": true
      },
      "uses": {
        "notation": "uses"
      }
    }
  },
  "model": {
    "bausteinsicht": {
      "kind": "system",
      "title": "Bausteinsicht",
      "description": "Architecture-as-code tool with draw.io as visual frontend and bidirectional synchronization",
      "children": {
        "cli": {
          "kind": "container",
          "title": "CLI",
          "description": "Command-line interface providing validate, sync, export, and watch commands",
          "technology": "Go / Cobra",
          "children": {
            "core": {
              "kind": "component",
              "title": "Core",
              "description": "Root command wiring, init, sync, validate, watch, and template resolution",
              "technology": "Go"
            },
            "add": {
              "kind": "component",
              "title": "Add",
              "description": "Add element/relationship/view/specification/pattern subcommands",
              "technology": "Go"
            },
            "export_cmds": {
              "kind": "component",
              "title": "Export Commands",
              "description": "export, export-diagram, export-table, and export-sequence subcommands",
              "technology": "Go"
            },
            "analysis": {
              "kind": "component",
              "title": "Analysis",
              "description": "find, show, status, stale, health, graph, and lint subcommands",
              "technology": "Go"
            },
            "evolution": {
              "kind": "component",
              "title": "Evolution",
              "description": "snapshot (save/list/diff/restore/delete), diff, and changelog subcommands",
              "technology": "Go"
            },
            "tooling": {
              "kind": "component",
              "title": "Tooling",
              "description": "import, generate-template, layout, schema, and workspace subcommands",
              "technology": "Go"
            },
            "interactive": {
              "kind": "component",
              "title": "Interactive",
              "description": "repl, overlay, and adr subcommands",
              "technology": "Go"
            }
          }
        },
        "drawio": {
          "kind": "container",
          "title": "draw.io",
          "description": "draw.io XML document handling — elements, connectors, templates, and labels",
          "technology": "Go / etree",
          "children": {
            "connector": {
              "kind": "component",
              "title": "Connector",
              "description": "Connector/relationship CRUD for edges between elements",
              "technology": "Go"
            },
            "document": {
              "kind": "component",
              "title": "Document",
              "description": "XML parsing, page management, and file I/O for .drawio files",
              "technology": "Go"
            },
            "element": {
              "kind": "component",
              "title": "Element",
              "description": "Element CRUD operations on mxGraphModel objects and mxCells",
              "technology": "Go"
            },
            "label": {
              "kind": "component",
              "title": "Label",
              "description": "HTML label generation and parsing for element display text",
              "technology": "Go"
            },
            "template": {
              "kind": "component",
              "title": "Template",
              "description": "Template loading and style lookup from .drawio template files",
              "technology": "Go"
            }
          }
        },
        "constraints": {
          "kind": "container",
          "title": "Constraints",
          "description": "Validation constraints for model linting and consistency checking",
          "technology": "Go"
        },
        "diagram": {
          "kind": "container",
          "title": "Diagram",
          "description": "Text-based diagram export to Mermaid C4 and PlantUML formats with markdown wrapping",
          "technology": "Go",
          "children": {
            "mermaid_c4": {
              "kind": "component",
              "title": "Mermaid C4",
              "description": "Mermaid C4 diagram generation with C4 level detection",
              "technology": "Go"
            },
            "markdown": {
              "kind": "component",
              "title": "Markdown",
              "description": "Markdown document wrapper for multiple diagram pages",
              "technology": "Go"
            }
          }
        },
        "exporter": {
          "kind": "container",
          "title": "Exporter",
          "description": "Architecture export to Structurizr DSL and other formats",
          "technology": "Go",
          "children": {
            "structurizr": {
              "kind": "component",
              "title": "Structurizr",
              "description": "Structurizr DSL export with smart variable naming",
              "technology": "Go"
            }
          }
        },
        "export": {
          "kind": "container",
          "title": "Export",
          "description": "Export diagrams to PNG, SVG, and other visual formats via draw.io CLI",
          "technology": "Go"
        },
        "importer": {
          "kind": "container",
          "title": "Importer",
          "description": "Import architecture from Structurizr DSL, LikeC4, and XMI/Enterprise Architect formats",
          "technology": "Go",
          "children": {
            "structurizr": {
              "kind": "component",
              "title": "Structurizr",
              "description": "Structurizr DSL parsing and model conversion",
              "technology": "Go"
            },
            "likec4": {
              "kind": "component",
              "title": "LikeC4",
              "description": "LikeC4 DSL parsing and model conversion",
              "technology": "Go"
            },
            "xmi": {
              "kind": "component",
              "title": "XMI",
              "description": "XMI/Enterprise Architect parsing and model conversion. Buffers the whole file in memory and converts Windows-1252 to UTF-8 before parsing (peak RSS ~2x file size); a 200MB read cap is enforced.",
              "technology": "Go"
            }
          }
        },
        "lsp": {
          "kind": "container",
          "title": "Language Server",
          "description": "Language Server Protocol implementation for VS Code and other editors",
          "technology": "Go"
        },
        "search": {
          "kind": "container",
          "title": "Search",
          "description": "Element and relationship search with filtering and pattern matching",
          "technology": "Go"
        },
        "table": {
          "kind": "container",
          "title": "Table",
          "description": "Export architecture to CSV and Markdown table formats",
          "technology": "Go"
        },
        "model": {
          "kind": "container",
          "title": "Model",
          "description": "JSONC architecture model management — loading, validation, and mutation",
          "technology": "Go",
          "children": {
            "loader": {
              "kind": "component",
              "title": "Loader",
              "description": "JSONC read/write with comment stripping and trailing comma handling",
              "technology": "Go"
            },
            "patch": {
              "kind": "component",
              "title": "Patch",
              "description": "Comment-preserving JSONC mutations for reverse sync",
              "technology": "Go"
            },
            "resolve": {
              "kind": "component",
              "title": "Resolve",
              "description": "Dot-notation element resolution and wildcard pattern matching",
              "technology": "Go"
            },
            "types": {
              "kind": "component",
              "title": "Types",
              "description": "Core struct definitions for elements, relationships, views, and specification",
              "technology": "Go"
            },
            "validate": {
              "kind": "component",
              "title": "Validate",
              "description": "Model validation rules for elements, relationships, and views",
              "technology": "Go"
            }
          }
        },
        "sync": {
          "kind": "container",
          "title": "Sync Engine",
          "description": "Bidirectional synchronization engine between JSONC model and draw.io diagrams",
          "technology": "Go",
          "children": {
            "conflict": {
              "kind": "component",
              "title": "Conflict",
              "description": "Conflict detection and resolution when both model and diagram changed",
              "technology": "Go"
            },
            "diff": {
              "kind": "component",
              "title": "Diff",
              "description": "Three-way change detection comparing model, diagram, and last-sync state",
              "technology": "Go"
            },
            "engine": {
              "kind": "component",
              "title": "Engine",
              "description": "Main sync orchestrator coordinating diff, forward, reverse, and conflict resolution",
              "technology": "Go"
            },
            "forward": {
              "kind": "component",
              "title": "Forward Sync",
              "description": "Applies model changes to draw.io diagrams (model → drawio)",
              "technology": "Go"
            },
            "reverse": {
              "kind": "component",
              "title": "Reverse Sync",
              "description": "Applies draw.io changes back to the JSONC model (drawio → model)",
              "technology": "Go"
            },
            "state": {
              "kind": "component",
              "title": "State",
              "description": "Sync state persistence using SHA256 hashes for change detection",
              "technology": "Go"
            }
          }
        },
        "watcher": {
          "kind": "container",
          "title": "Watcher",
          "description": "File system monitoring for automatic sync on model or diagram changes",
          "technology": "Go / fsnotify"
        },

        // internal/benchmarks, internal/chaos, and internal/e2eplan are
        // deliberately NOT modeled here: they are test/tooling packages
        // (performance benchmarks, chaos testing, and the e2e-test-plan
        // report generator's own registry), not part of the product's own
        // architecture — see the "container" spec definition above ("A Go
        // package group within the system"). See #524.
        "changelog": {
          "kind": "container",
          "title": "Changelog",
          "description": "Architecture changelog generation between two git refs",
          "technology": "Go"
        },
        "diff": {
          "kind": "container",
          "title": "Diff",
          "description": "As-is vs. to-be architecture comparison",
          "technology": "Go"
        },
        "graph": {
          "kind": "container",
          "title": "Graph",
          "description": "Relationship graph analysis — cycle detection and dependency depth",
          "technology": "Go"
        },
        "health": {
          "kind": "container",
          "title": "Health",
          "description": "Architecture health scoring — completeness, conformance, and complexity",
          "technology": "Go"
        },
        "layout": {
          "kind": "container",
          "title": "Layout",
          "description": "Auto-layout algorithms for positioning elements in draw.io diagrams",
          "technology": "Go"
        },
        "overlay": {
          "kind": "container",
          "title": "Overlay",
          "description": "Metric heatmap overlay application and removal on draw.io diagrams",
          "technology": "Go"
        },
        "schema": {
          "kind": "container",
          "title": "Schema",
          "description": "JSON Schema generation from Go model types for IDE autocompletion",
          "technology": "Go"
        },
        "snapshot": {
          "kind": "container",
          "title": "Snapshot",
          "description": "Versioned architecture snapshot storage and restore",
          "technology": "Go"
        },
        "stale": {
          "kind": "container",
          "title": "Stale",
          "description": "Detects unused or forgotten architecture elements via git history and ADR/status metadata",
          "technology": "Go"
        },
        "template": {
          "kind": "container",
          "title": "Template",
          "description": "draw.io template generation from element specification (shapes, layout)",
          "technology": "Go"
        },
        "workspace": {
          "kind": "container",
          "title": "Workspace",
          "description": "Multi-model workspace configuration loading and merging",
          "technology": "Go"
        }
      }
    },
    "developer": {
      "kind": "actor",
      "title": "Developer",
      "description": "Developer using the Bausteinsicht CLI to manage architecture models"
    },
    "drawio_app": {
      "kind": "external_system",
      "title": "draw.io App",
      "description": "draw.io desktop or web application for visual diagram editing"
    },
    "ide": {
      "kind": "external_system",
      "title": "IDE",
      "description": "IDE with JSON Schema support for JSONC editing with autocompletion"
    },
    "architect": {
      "kind": "actor",
      "title": "Software Architect",
      "description": "Edits the JSONC model or draw.io diagrams directly and runs bausteinsicht CLI commands (sync, init, watch, stale, ...). Deliberately not included in the \"context\" view's structural diagram (see that chapter's NOTE) — modeled here so dynamicViews (chapter 6 runtime scenarios) can reference it as a real participant."
    },
    "llm_agent": {
      "kind": "actor",
      "title": "LLM Agent",
      "description": "Uses bausteinsicht CLI commands (add, sync, ...) programmatically, typically with --format json output. Same context-view exclusion rationale as \"architect\"."
    },
    "git": {
      "kind": "external_system",
      "title": "Git",
      "description": "Version control read via `git log` by stale detection and changelog generation; optional (both degrade gracefully outside a git repository). Same context-view exclusion rationale as \"architect\"."
    }
  },
  "relationships": [
    {
      "from": "developer",
      "to": "bausteinsicht.cli",
      "label": "runs commands",
      "kind": "uses"
    },
    {
      "from": "developer",
      "to": "ide",
      "label": "edits JSONC",
      "kind": "uses"
    },
    {
      "from": "developer",
      "to": "drawio_app",
      "label": "edits diagrams",
      "kind": "uses"
    },
    {
      "from": "ide",
      "to": "bausteinsicht.model",
      "label": "JSON Schema validation",
      "kind": "uses"
    },
    {
      "from": "drawio_app",
      "to": "bausteinsicht.drawio.document",
      "label": "modifies .drawio file",
      "kind": "uses"
    },
    {
      "from": "bausteinsicht.cli",
      "to": "bausteinsicht.model.loader",
      "label": "loads/saves JSONC",
      "kind": "uses"
    },
    {
      "from": "bausteinsicht.cli",
      "to": "bausteinsicht.model.validate",
      "label": "validates model",
      "kind": "uses"
    },
    {
      "from": "bausteinsicht.cli",
      "to": "bausteinsicht.sync.engine",
      "label": "triggers sync",
      "kind": "uses"
    },
    {
      "from": "bausteinsicht.cli",
      "to": "bausteinsicht.watcher",
      "label": "starts watch mode",
      "kind": "uses"
    },
    {
      "from": "bausteinsicht.cli",
      "to": "bausteinsicht.diagram",
      "label": "exports Mermaid diagrams",
      "kind": "uses"
    },
    {
      "from": "bausteinsicht.cli",
      "to": "bausteinsicht.export",
      "label": "triggers export",
      "kind": "uses"
    },
    {
      "from": "bausteinsicht.cli",
      "to": "bausteinsicht.importer",
      "label": "imports models",
      "kind": "uses"
    },
    {
      "from": "bausteinsicht.cli",
      "to": "bausteinsicht.exporter",
      "label": "exports DSL",
      "kind": "uses"
    },
    {
      "from": "bausteinsicht.cli",
      "to": "bausteinsicht.table",
      "label": "exports tables",
      "kind": "uses"
    },
    {
      "from": "bausteinsicht.cli",
      "to": "bausteinsicht.search",
      "label": "searches elements",
      "kind": "uses"
    },
    {
      "from": "bausteinsicht.cli",
      "to": "bausteinsicht.constraints",
      "label": "validates constraints",
      "kind": "uses"
    },
    {
      "from": "bausteinsicht.cli",
      "to": "bausteinsicht.lsp",
      "label": "starts language server",
      "kind": "uses"
    },
    {
      "from": "bausteinsicht.cli",
      "to": "bausteinsicht.changelog",
      "label": "triggers changelog generation",
      "kind": "uses"
    },
    {
      "from": "bausteinsicht.cli",
      "to": "bausteinsicht.diff",
      "label": "triggers as-is/to-be diff",
      "kind": "uses"
    },
    {
      "from": "bausteinsicht.cli",
      "to": "bausteinsicht.graph",
      "label": "triggers graph analysis",
      "kind": "uses"
    },
    {
      "from": "bausteinsicht.cli",
      "to": "bausteinsicht.health",
      "label": "triggers health scoring",
      "kind": "uses"
    },
    {
      "from": "bausteinsicht.cli",
      "to": "bausteinsicht.layout",
      "label": "triggers auto-layout",
      "kind": "uses"
    },
    {
      "from": "bausteinsicht.cli",
      "to": "bausteinsicht.overlay",
      "label": "triggers overlay apply/remove",
      "kind": "uses"
    },
    {
      "from": "bausteinsicht.cli",
      "to": "bausteinsicht.schema",
      "label": "triggers schema generation",
      "kind": "uses"
    },
    {
      "from": "bausteinsicht.cli",
      "to": "bausteinsicht.snapshot",
      "label": "manages snapshots",
      "kind": "uses"
    },
    {
      "from": "bausteinsicht.cli",
      "to": "bausteinsicht.stale",
      "label": "triggers stale-element detection",
      "kind": "uses"
    },
    {
      "from": "bausteinsicht.cli",
      "to": "bausteinsicht.template",
      "label": "generates draw.io templates",
      "kind": "uses"
    },
    {
      "from": "bausteinsicht.cli",
      "to": "bausteinsicht.workspace",
      "label": "loads/merges workspace config",
      "kind": "uses"
    },
    {
      "from": "bausteinsicht.sync.engine",
      "to": "bausteinsicht.sync.diff",
      "label": "detects changes",
      "kind": "uses"
    },
    {
      "from": "bausteinsicht.sync.engine",
      "to": "bausteinsicht.sync.forward",
      "label": "model to drawio",
      "kind": "uses"
    },
    {
      "from": "bausteinsicht.sync.engine",
      "to": "bausteinsicht.sync.reverse",
      "label": "drawio to model",
      "kind": "uses"
    },
    {
      "from": "bausteinsicht.sync.engine",
      "to": "bausteinsicht.sync.state",
      "label": "loads/saves state",
      "kind": "uses"
    },
    {
      "from": "bausteinsicht.sync.engine",
      "to": "bausteinsicht.sync.conflict",
      "label": "resolves conflicts",
      "kind": "uses"
    },
    {
      "from": "bausteinsicht.sync.forward",
      "to": "bausteinsicht.drawio.element",
      "label": "creates/updates elements",
      "kind": "uses"
    },
    {
      "from": "bausteinsicht.sync.forward",
      "to": "bausteinsicht.drawio.connector",
      "label": "creates/updates connectors",
      "kind": "uses"
    },
    {
      "from": "bausteinsicht.sync.reverse",
      "to": "bausteinsicht.model.patch",
      "label": "comment-preserving updates",
      "kind": "uses"
    },
    {
      "from": "bausteinsicht.drawio.element",
      "to": "bausteinsicht.drawio.label",
      "label": "generates labels",
      "kind": "uses"
    },
    {
      "from": "bausteinsicht.drawio.element",
      "to": "bausteinsicht.drawio.template",
      "label": "looks up styles",
      "kind": "uses"
    },
    {
      "from": "bausteinsicht.drawio.element",
      "to": "bausteinsicht.drawio.document",
      "label": "modifies pages",
      "kind": "uses"
    },
    {
      "from": "bausteinsicht.drawio.connector",
      "to": "bausteinsicht.drawio.document",
      "label": "modifies pages",
      "kind": "uses"
    },
    {
      "from": "bausteinsicht.model.loader",
      "to": "bausteinsicht.model.resolve",
      "label": "resolves element IDs",
      "kind": "uses"
    },
    {
      "from": "bausteinsicht.model.loader",
      "to": "bausteinsicht.model.types",
      "label": "populates structs",
      "kind": "uses"
    },
    {
      "from": "bausteinsicht.model.validate",
      "to": "bausteinsicht.model.types",
      "label": "reads model structs",
      "kind": "uses"
    },
    {
      "from": "bausteinsicht.model.validate",
      "to": "bausteinsicht.model.resolve",
      "label": "resolves patterns",
      "kind": "uses"
    },
    {
      "from": "bausteinsicht.model.patch",
      "to": "bausteinsicht.model.types",
      "label": "reads model structs",
      "kind": "uses"
    },
    {
      "from": "bausteinsicht.watcher",
      "to": "bausteinsicht.sync.engine",
      "label": "triggers on file change",
      "kind": "uses"
    },
    {
      "from": "bausteinsicht.export",
      "to": "bausteinsicht.drawio.document",
      "label": "reads diagram pages",
      "kind": "uses"
    },
    {
      "from": "bausteinsicht.diagram",
      "to": "bausteinsicht.model",
      "label": "reads model for export",
      "kind": "uses"
    },
    {
      "from": "bausteinsicht.diagram.mermaid_c4",
      "to": "bausteinsicht.model.types",
      "label": "renders elements",
      "kind": "uses"
    },
    {
      "from": "bausteinsicht.diagram.markdown",
      "to": "bausteinsicht.diagram.mermaid_c4",
      "label": "wraps diagrams",
      "kind": "uses"
    },
    {
      "from": "bausteinsicht.importer",
      "to": "bausteinsicht.model",
      "label": "populates model",
      "kind": "uses"
    },
    {
      "from": "bausteinsicht.importer.structurizr",
      "to": "bausteinsicht.model.types",
      "label": "creates elements",
      "kind": "uses"
    },
    {
      "from": "bausteinsicht.importer.likec4",
      "to": "bausteinsicht.model.types",
      "label": "creates elements",
      "kind": "uses"
    },
    {
      "from": "bausteinsicht.exporter.structurizr",
      "to": "bausteinsicht.model",
      "label": "reads model",
      "kind": "uses"
    },
    {
      "from": "bausteinsicht.search",
      "to": "bausteinsicht.model",
      "label": "searches elements",
      "kind": "uses"
    },
    {
      "from": "bausteinsicht.search",
      "to": "bausteinsicht.model.resolve",
      "label": "resolves patterns",
      "kind": "uses"
    },
    {
      "from": "bausteinsicht.table",
      "to": "bausteinsicht.model",
      "label": "reads model",
      "kind": "uses"
    },
    {
      "from": "bausteinsicht.table",
      "to": "bausteinsicht.diagram",
      "label": "optionally uses diagrams",
      "kind": "uses"
    },
    {
      "from": "bausteinsicht.constraints",
      "to": "bausteinsicht.model",
      "label": "validates model",
      "kind": "uses"
    },
    {
      "from": "bausteinsicht.constraints",
      "to": "bausteinsicht.model.validate",
      "label": "extends validation",
      "kind": "uses"
    },
    {
      "from": "bausteinsicht.lsp",
      "to": "bausteinsicht.model",
      "label": "indexes for completion",
      "kind": "uses"
    },
    {
      "from": "bausteinsicht.changelog",
      "to": "bausteinsicht.diff",
      "label": "computes as-is/to-be delta per ref",
      "kind": "uses"
    },
    {
      "from": "bausteinsicht.changelog",
      "to": "bausteinsicht.model",
      "label": "loads model at each git ref",
      "kind": "uses"
    },
    {
      "from": "bausteinsicht.diff",
      "to": "bausteinsicht.model",
      "label": "reads as-is/to-be sections",
      "kind": "uses"
    },
    {
      "from": "bausteinsicht.graph",
      "to": "bausteinsicht.model",
      "label": "reads elements and relationships",
      "kind": "uses"
    },
    {
      "from": "bausteinsicht.health",
      "to": "bausteinsicht.model",
      "label": "reads elements for scoring",
      "kind": "uses"
    },
    {
      "from": "bausteinsicht.layout",
      "to": "bausteinsicht.drawio",
      "label": "writes computed positions",
      "kind": "uses"
    },
    {
      "from": "bausteinsicht.layout",
      "to": "bausteinsicht.model",
      "label": "reads element hierarchy",
      "kind": "uses"
    },
    {
      "from": "bausteinsicht.schema",
      "to": "bausteinsicht.model",
      "label": "reflects Go struct types",
      "kind": "uses"
    },
    {
      "from": "bausteinsicht.snapshot",
      "to": "bausteinsicht.model",
      "label": "serializes/restores model state",
      "kind": "uses"
    },
    {
      "from": "bausteinsicht.stale",
      "to": "bausteinsicht.drawio",
      "label": "reads/writes risk-color marking",
      "kind": "uses"
    },
    {
      "from": "bausteinsicht.stale",
      "to": "bausteinsicht.model",
      "label": "reads status/ADR metadata",
      "kind": "uses"
    },
    {
      "from": "bausteinsicht.stale",
      "to": "bausteinsicht.overlay",
      "label": "reuses heatmap color scale",
      "kind": "uses"
    },
    {
      "from": "bausteinsicht.template",
      "to": "bausteinsicht.drawio",
      "label": "generates template shapes/styles",
      "kind": "uses"
    },
    {
      "from": "bausteinsicht.template",
      "to": "bausteinsicht.model",
      "label": "reads element kind specification",
      "kind": "uses"
    },
    {
      "from": "bausteinsicht.workspace",
      "to": "bausteinsicht.model",
      "label": "merges multiple models",
      "kind": "uses"
    }
  ],
  "views": {
    "containers": {
      "title": "Container View",
      "scope": "bausteinsicht",
      "include": [
        "developer",
        "drawio_app",
        "ide",
        "bausteinsicht.*"
      ],
      "description": "Internal containers of Bausteinsicht with external actor interactions"
    },
    "context": {
      "title": "System Context",
      "include": [
        "developer",
        "drawio_app",
        "ide",
        "bausteinsicht"
      ],
      "description": "High-level view showing Bausteinsicht and its external actors"
    },
    "drawio-components": {
      "title": "draw.io Package Components",
      "scope": "bausteinsicht.drawio",
      "include": [
        "bausteinsicht.drawio.*",
        "bausteinsicht.sync",
        "bausteinsicht.export",
        "drawio_app"
      ],
      "description": "Internal components of the draw.io XML handling package with external callers"
    },
    "model-components": {
      "title": "Model Package Components",
      "scope": "bausteinsicht.model",
      "include": [
        "bausteinsicht.model.*",
        "bausteinsicht.cli",
        "bausteinsicht.sync",
        "ide"
      ],
      "description": "Internal components of the JSONC model management package with external callers"
    },
    "sync-components": {
      "title": "Sync Engine Components",
      "scope": "bausteinsicht.sync",
      "include": [
        "bausteinsicht.sync.*",
        "bausteinsicht.model",
        "bausteinsicht.drawio",
        "bausteinsicht.cli",
        "bausteinsicht.watcher"
      ],
      "description": "Internal components of the bidirectional sync engine and its key dependencies"
    },
    "diagram-components": {
      "title": "Diagram Package Components",
      "scope": "bausteinsicht.diagram",
      "include": [
        "bausteinsicht.diagram.*",
        "bausteinsicht.model",
        "bausteinsicht.cli"
      ],
      "description": "Text-based diagram export components (Mermaid C4, PlantUML) and markdown wrapping"
    },
    "importer-components": {
      "title": "Importer Package Components",
      "scope": "bausteinsicht.importer",
      "include": [
        "bausteinsicht.importer.*",
        "bausteinsicht.model",
        "bausteinsicht.cli"
      ],
      "description": "Import components for Structurizr DSL and LikeC4 format conversion to Bausteinsicht model"
    },
    "exporter-components": {
      "title": "Exporter Package Components",
      "scope": "bausteinsicht.exporter",
      "include": [
        "bausteinsicht.exporter.*",
        "bausteinsicht.model",
        "bausteinsicht.cli"
      ],
      "description": "Export components for converting Bausteinsicht model to external formats (Structurizr DSL)"
    },
    "search-components": {
      "title": "Search Package Components",
      "scope": "bausteinsicht.search",
      "include": [
        "bausteinsicht.search",
        "bausteinsicht.model",
        "bausteinsicht.cli"
      ],
      "description": "Element and relationship search with pattern matching and filtering"
    },
    "cli-components": {
      "title": "CLI Package Components",
      "scope": "bausteinsicht.cli",
      "include": [
        "bausteinsicht.cli.*",
        "bausteinsicht.model",
        "bausteinsicht.sync",
        "bausteinsicht.watcher"
      ],
      "description": "CLI subcommand clusters, grouped by concern rather than one component per file"
    }
  },
  "dynamicViews": [
    {
      "key": "sync-command",
      "title": "Sync Command",
      "description": "The most important runtime scenario: what happens when the user runs `bausteinsicht sync`. Conflict resolution (model wins) happens inside sync.engine, between DetectChanges and Apply, and isn't broken out as separate steps here.",
      "steps": [
        {
          "index": 1,
          "from": "architect",
          "to": "bausteinsicht.cli.core",
          "label": "bausteinsicht sync"
        },
        {
          "index": 2,
          "from": "bausteinsicht.cli.core",
          "to": "bausteinsicht.model.loader",
          "label": "Load(model.jsonc)"
        },
        {
          "index": 3,
          "from": "bausteinsicht.model.loader",
          "to": "bausteinsicht.cli.core",
          "label": "BausteinsichtModel",
          "type": "return"
        },
        {
          "index": 4,
          "from": "bausteinsicht.cli.core",
          "to": "bausteinsicht.drawio.document",
          "label": "LoadDocument(arch.drawio) + LoadTemplate(template.drawio)"
        },
        {
          "index": 5,
          "from": "bausteinsicht.drawio.document",
          "to": "bausteinsicht.cli.core",
          "label": "Document, TemplateSet",
          "type": "return"
        },
        {
          "index": 6,
          "from": "bausteinsicht.cli.core",
          "to": "bausteinsicht.sync.state",
          "label": "LoadState(.bausteinsicht-sync)"
        },
        {
          "index": 7,
          "from": "bausteinsicht.sync.state",
          "to": "bausteinsicht.cli.core",
          "label": "SyncState",
          "type": "return"
        },
        {
          "index": 8,
          "from": "bausteinsicht.cli.core",
          "to": "bausteinsicht.sync.engine",
          "label": "Run(model, document, state, templates, opts)"
        },
        {
          "index": 9,
          "from": "bausteinsicht.sync.engine",
          "to": "bausteinsicht.sync.diff",
          "label": "DetectChanges(model, document, state)"
        },
        {
          "index": 10,
          "from": "bausteinsicht.sync.diff",
          "to": "bausteinsicht.sync.engine",
          "label": "ChangeSet (conflicts resolved here: model wins)",
          "type": "return"
        },
        {
          "index": 11,
          "from": "bausteinsicht.sync.engine",
          "to": "bausteinsicht.sync.forward",
          "label": "Apply(modelChanges, document, templates, opts)"
        },
        {
          "index": 12,
          "from": "bausteinsicht.sync.forward",
          "to": "bausteinsicht.sync.engine",
          "label": "forward result (adds metadata + legend per view)",
          "type": "return"
        },
        {
          "index": 13,
          "from": "bausteinsicht.sync.engine",
          "to": "bausteinsicht.sync.reverse",
          "label": "Apply(drawioChanges, model)"
        },
        {
          "index": 14,
          "from": "bausteinsicht.sync.reverse",
          "to": "bausteinsicht.sync.engine",
          "label": "reverse result",
          "type": "return"
        },
        {
          "index": 15,
          "from": "bausteinsicht.sync.engine",
          "to": "bausteinsicht.cli.core",
          "label": "SyncResult",
          "type": "return"
        },
        {
          "index": 16,
          "from": "bausteinsicht.cli.core",
          "to": "bausteinsicht.model.loader",
          "label": "PatchSave(model.jsonc) — comment-preserving, full Save fallback"
        },
        {
          "index": 17,
          "from": "bausteinsicht.cli.core",
          "to": "bausteinsicht.drawio.document",
          "label": "SaveDocument(arch.drawio)"
        },
        {
          "index": 18,
          "from": "bausteinsicht.cli.core",
          "to": "bausteinsicht.sync.state",
          "label": "SaveState(.bausteinsicht-sync) — written last, only after both writes succeed"
        },
        {
          "index": 19,
          "from": "bausteinsicht.cli.core",
          "to": "architect",
          "label": "Summary of changes",
          "type": "return"
        }
      ]
    },
    {
      "key": "watch-mode",
      "title": "Watch Mode",
      "description": "The continuous sync loop triggered by file changes, with a 300ms debounce (editors often fire multiple save events per edit).",
      "steps": [
        {
          "index": 1,
          "from": "architect",
          "to": "bausteinsicht.cli.core",
          "label": "bausteinsicht watch"
        },
        {
          "index": 2,
          "from": "bausteinsicht.cli.core",
          "to": "bausteinsicht.watcher",
          "label": "Start(model.jsonc, arch.drawio)"
        },
        {
          "index": 3,
          "from": "bausteinsicht.watcher",
          "to": "bausteinsicht.watcher",
          "label": "on file change: debounce 300ms"
        },
        {
          "index": 4,
          "from": "bausteinsicht.watcher",
          "to": "bausteinsicht.sync.engine",
          "label": "Run(model, document, state, templates, opts)"
        },
        {
          "index": 5,
          "from": "bausteinsicht.sync.engine",
          "to": "bausteinsicht.watcher",
          "label": "SyncResult",
          "type": "return"
        },
        {
          "index": 6,
          "from": "bausteinsicht.watcher",
          "to": "architect",
          "label": "Log + display summary of changes",
          "type": "return"
        },
        {
          "index": 7,
          "from": "architect",
          "to": "bausteinsicht.cli.core",
          "label": "Ctrl+C"
        },
        {
          "index": 8,
          "from": "bausteinsicht.cli.core",
          "to": "bausteinsicht.watcher",
          "label": "Stop()"
        }
      ]
    },
    {
      "key": "init-command",
      "title": "Init Command",
      "description": "Bootstraps a new project: sample model + default template + an initial sync against an empty draw.io document.",
      "steps": [
        {
          "index": 1,
          "from": "architect",
          "to": "bausteinsicht.cli.core",
          "label": "bausteinsicht init"
        },
        {
          "index": 2,
          "from": "bausteinsicht.cli.core",
          "to": "bausteinsicht.cli.core",
          "label": "check if files already exist (abort with error if so)"
        },
        {
          "index": 3,
          "from": "bausteinsicht.cli.core",
          "to": "bausteinsicht.model.loader",
          "label": "Save(model.jsonc, sample specification + example elements)"
        },
        {
          "index": 4,
          "from": "bausteinsicht.cli.core",
          "to": "bausteinsicht.sync.engine",
          "label": "Run(model, document=empty, state=empty, templates, opts)"
        },
        {
          "index": 5,
          "from": "bausteinsicht.sync.engine",
          "to": "bausteinsicht.cli.core",
          "label": "initial arch.drawio written",
          "type": "return"
        },
        {
          "index": 6,
          "from": "bausteinsicht.cli.core",
          "to": "architect",
          "label": "Project initialized. Open arch.drawio in draw.io.",
          "type": "return"
        }
      ]
    },
    {
      "key": "llm-driven-modification",
      "title": "LLM-Driven Modification",
      "description": "How an LLM agent uses CLI commands to modify the architecture. `add` only edits the JSON model — it never triggers sync automatically (single responsibility, lets an agent batch changes before syncing).",
      "steps": [
        {
          "index": 1,
          "from": "llm_agent",
          "to": "bausteinsicht.cli.add",
          "label": "bausteinsicht add element ‑‑id cache ‑‑kind container ‑‑title \"Redis Cache\" ‑‑parent webshop ‑‑format json"
        },
        {
          "index": 2,
          "from": "bausteinsicht.cli.add",
          "to": "bausteinsicht.model.loader",
          "label": "Load(model.jsonc)"
        },
        {
          "index": 3,
          "from": "bausteinsicht.cli.add",
          "to": "bausteinsicht.model.validate",
          "label": "Validate(kind exists, parent exists)"
        },
        {
          "index": 4,
          "from": "bausteinsicht.model.validate",
          "to": "bausteinsicht.cli.add",
          "label": "ok, or { \"error\": ... }",
          "type": "return"
        },
        {
          "index": 5,
          "from": "bausteinsicht.cli.add",
          "to": "bausteinsicht.model.loader",
          "label": "Save(model.jsonc, updatedModel)"
        },
        {
          "index": 6,
          "from": "bausteinsicht.cli.add",
          "to": "llm_agent",
          "label": "{ \"status\": \"added\", \"id\": \"webshop.cache\" }",
          "type": "return"
        },
        {
          "index": 7,
          "from": "llm_agent",
          "to": "bausteinsicht.cli.core",
          "label": "bausteinsicht sync — separate command to update draw.io diagram"
        }
      ]
    },
    {
      "key": "import-from-external-formats",
      "title": "Import from Structurizr / LikeC4 / XMI",
      "description": "How an existing model (Structurizr DSL, LikeC4, or XMI/Enterprise Architect) is brought into Bausteinsicht. The importer never touches draw.io — it only produces a model, immediately syncable with `bausteinsicht sync`. The XMI path additionally buffers the whole file in memory and converts Windows-1252 to UTF-8 before parsing (peak RSS ~2x file size, 200MB read cap) — a materially different cost profile from the other two formats, though the CLI-level flow shown here is the same.",
      "steps": [
        {
          "index": 1,
          "from": "architect",
          "to": "bausteinsicht.cli.tooling",
          "label": "bausteinsicht import workspace.dsl ‑‑from structurizr|likec4|xmi [‑‑dry-run]"
        },
        {
          "index": 2,
          "from": "bausteinsicht.cli.tooling",
          "to": "bausteinsicht.importer",
          "label": "Import(file, format)"
        },
        {
          "index": 3,
          "from": "bausteinsicht.importer",
          "to": "bausteinsicht.importer",
          "label": "parse source, map people/systems/containers + relationships"
        },
        {
          "index": 4,
          "from": "bausteinsicht.importer",
          "to": "bausteinsicht.cli.tooling",
          "label": "ImportResult{Model, Warnings}",
          "type": "return"
        },
        {
          "index": 5,
          "from": "bausteinsicht.cli.tooling",
          "to": "architect",
          "label": "‑‑dry-run: print generated JSONC to stdout",
          "type": "return"
        },
        {
          "index": 6,
          "from": "bausteinsicht.cli.tooling",
          "to": "bausteinsicht.model.loader",
          "label": "write: Save(architecture.jsonc, model) — exit 2 if exists without ‑‑force"
        },
        {
          "index": 7,
          "from": "bausteinsicht.cli.tooling",
          "to": "architect",
          "label": "\"Imported model written\" + warnings",
          "type": "return"
        }
      ]
    },
    {
      "key": "repl-save",
      "title": "REPL Save: Patch vs. Full-Save Fallback",
      "description": "The REPL keeps the model in memory and, on `save`, chooses how to persist so JSONC comments survive when possible — the key data-integrity flow. Validation runs before any write; pure additions take the comment-preserving patch path, modifications/deletions fall back to a full rewrite with a visible warning about comment loss. The same patch primitives back the non-interactive `add` commands.",
      "steps": [
        {
          "index": 1,
          "from": "architect",
          "to": "bausteinsicht.cli.interactive",
          "label": "add / remove / edit ... then `save`"
        },
        {
          "index": 2,
          "from": "bausteinsicht.cli.interactive",
          "to": "bausteinsicht.model.validate",
          "label": "Validate(in-memory model)"
        },
        {
          "index": 3,
          "from": "bausteinsicht.model.validate",
          "to": "bausteinsicht.cli.interactive",
          "label": "valid, or \"save aborted — N validation error(s)\"",
          "type": "return"
        },
        {
          "index": 4,
          "from": "bausteinsicht.cli.interactive",
          "to": "bausteinsicht.model.patch",
          "label": "pure additions: PatchInsert / AppendArrayEntry (comments preserved)"
        },
        {
          "index": 5,
          "from": "bausteinsicht.cli.interactive",
          "to": "bausteinsicht.model.loader",
          "label": "any modification/deletion: Save(model.jsonc) full rewrite (comments may be lost)"
        },
        {
          "index": 6,
          "from": "bausteinsicht.cli.interactive",
          "to": "architect",
          "label": "\"Saved\"",
          "type": "return"
        }
      ]
    },
    {
      "key": "stale-detection",
      "title": "Stale Detection",
      "description": "How `bausteinsicht stale` flags forgotten elements using git history. Outside a git repository, git lookups degrade gracefully (no date) and detection falls back to view/relationship membership checks alone.",
      "steps": [
        {
          "index": 1,
          "from": "architect",
          "to": "bausteinsicht.cli.analysis",
          "label": "bausteinsicht stale [‑‑days N]"
        },
        {
          "index": 2,
          "from": "bausteinsicht.cli.analysis",
          "to": "bausteinsicht.model.loader",
          "label": "Load(model.jsonc)"
        },
        {
          "index": 3,
          "from": "bausteinsicht.cli.analysis",
          "to": "bausteinsicht.stale",
          "label": "Detect(model, threshold)"
        },
        {
          "index": 4,
          "from": "bausteinsicht.stale",
          "to": "bausteinsicht.stale",
          "label": "per element: referenced by a view? by a relationship?"
        },
        {
          "index": 5,
          "from": "bausteinsicht.stale",
          "to": "git",
          "label": "last-modified date (git log ‑‑follow)"
        },
        {
          "index": 6,
          "from": "git",
          "to": "bausteinsicht.stale",
          "label": "date, or \"no history\"",
          "type": "return"
        },
        {
          "index": 7,
          "from": "bausteinsicht.stale",
          "to": "bausteinsicht.cli.analysis",
          "label": "stale elements, deterministically sorted",
          "type": "return"
        },
        {
          "index": 8,
          "from": "bausteinsicht.cli.analysis",
          "to": "architect",
          "label": "report (text / json)",
          "type": "return"
        }
      ]
    },
    {
      "key": "error-recovery",
      "title": "Error & Recovery: Failed Write During Sync",
      "description": "Why a failed or interrupted sync never corrupts the working files. The engine computes everything in memory first; each file is written afterwards via temp-file-plus-rename, and the state file is written last — so if an earlier write fails, state is left untouched and the next run re-detects and re-applies the same change with no manual repair. This linear rendering necessarily loses some of the branching/grouping nuance (\"atomic writes\" block, the write-fails/write-succeeds alt) that the hand-drawn version could show explicitly — see the step labels for the conditions that would otherwise be alt-branches.",
      "steps": [
        {
          "index": 1,
          "from": "architect",
          "to": "bausteinsicht.cli.core",
          "label": "bausteinsicht sync"
        },
        {
          "index": 2,
          "from": "bausteinsicht.cli.core",
          "to": "bausteinsicht.sync.engine",
          "label": "Run(...) — pure, in-memory"
        },
        {
          "index": 3,
          "from": "bausteinsicht.sync.engine",
          "to": "bausteinsicht.cli.core",
          "label": "SyncResult",
          "type": "return"
        },
        {
          "index": 4,
          "from": "bausteinsicht.cli.core",
          "to": "bausteinsicht.drawio.document",
          "label": "SaveDocument(arch.drawio) — atomic temp-file + rename"
        },
        {
          "index": 5,
          "from": "bausteinsicht.cli.core",
          "to": "bausteinsicht.sync.state",
          "label": "if write succeeded: SaveState(.bausteinsicht-sync), SHA-256 checksummed"
        },
        {
          "index": 6,
          "from": "bausteinsicht.cli.core",
          "to": "architect",
          "label": "if write failed: exit 1, original files intact, state unchanged",
          "type": "return"
        },
        {
          "index": 7,
          "from": "bausteinsicht.cli.core",
          "to": "architect",
          "label": "if write succeeded: summary",
          "type": "return"
        },
        {
          "index": 8,
          "from": "architect",
          "to": "bausteinsicht.cli.core",
          "label": "next run: bausteinsicht sync"
        },
        {
          "index": 9,
          "from": "bausteinsicht.cli.core",
          "to": "bausteinsicht.cli.core",
          "label": "state unchanged from failed run → DetectChanges re-finds same delta"
        },
        {
          "index": 10,
          "from": "bausteinsicht.cli.core",
          "to": "architect",
          "label": "completes the interrupted change, no manual repair",
          "type": "return"
        }
      ]
    },
    {
      "key": "add-family",
      "title": "Add: Relationship / View / Specification / From-Pattern",
      "description": "The non-element `add` subcommands: relationships between existing elements, views (include/exclude filters), specification entries (new element kinds), and pattern-based bulk generation. All are pure model edits, same shape as `add element` (see LLM-Driven Modification) — shown once here rather than four near-identical diagrams.",
      "steps": [
        {
          "index": 1,
          "from": "architect",
          "to": "bausteinsicht.cli.add",
          "label": "bausteinsicht add relationship ‑‑from a ‑‑to b ‑‑kind uses"
        },
        {
          "index": 2,
          "from": "bausteinsicht.cli.add",
          "to": "bausteinsicht.model.validate",
          "label": "Validate(both ends exist)"
        },
        {
          "index": 3,
          "from": "bausteinsicht.cli.add",
          "to": "bausteinsicht.model.loader",
          "label": "Save(model.jsonc, updatedModel)"
        },
        {
          "index": 4,
          "from": "architect",
          "to": "bausteinsicht.cli.add",
          "label": "bausteinsicht add view / add specification"
        },
        {
          "index": 5,
          "from": "bausteinsicht.cli.add",
          "to": "bausteinsicht.model.loader",
          "label": "Save(model.jsonc, updatedModel)"
        },
        {
          "index": 6,
          "from": "architect",
          "to": "bausteinsicht.cli.add",
          "label": "bausteinsicht add-from-pattern ‑‑pattern <name>"
        },
        {
          "index": 7,
          "from": "bausteinsicht.cli.add",
          "to": "bausteinsicht.model.resolve",
          "label": "resolve pattern placeholders against existing elements"
        },
        {
          "index": 8,
          "from": "bausteinsicht.model.resolve",
          "to": "bausteinsicht.cli.add",
          "label": "resolved element set",
          "type": "return"
        },
        {
          "index": 9,
          "from": "bausteinsicht.cli.add",
          "to": "bausteinsicht.model.loader",
          "label": "Save(model.jsonc, expandedModel)"
        },
        {
          "index": 10,
          "from": "bausteinsicht.cli.add",
          "to": "architect",
          "label": "confirmation per subcommand",
          "type": "return"
        }
      ]
    },
    {
      "key": "snapshot-management",
      "title": "Snapshot: Save / List / Diff / Restore / Delete",
      "description": "Versioned model captures. `save` writes a timestamped copy; `diff` compares two snapshots (or a snapshot against the live model) the same way `bausteinsicht diff` compares as-is vs. to-be; `restore` overwrites the live model from a snapshot (destructive, so it's the one step here worth calling out as such).",
      "steps": [
        {
          "index": 1,
          "from": "architect",
          "to": "bausteinsicht.cli.evolution",
          "label": "bausteinsicht snapshot save ‑‑label pre-refactor"
        },
        {
          "index": 2,
          "from": "bausteinsicht.cli.evolution",
          "to": "bausteinsicht.snapshot",
          "label": "capture current model.jsonc + metadata"
        },
        {
          "index": 3,
          "from": "bausteinsicht.snapshot",
          "to": "bausteinsicht.cli.evolution",
          "label": "written to .bausteinsicht-snapshots/",
          "type": "return"
        },
        {
          "index": 4,
          "from": "architect",
          "to": "bausteinsicht.cli.evolution",
          "label": "bausteinsicht snapshot list"
        },
        {
          "index": 5,
          "from": "bausteinsicht.cli.evolution",
          "to": "bausteinsicht.snapshot",
          "label": "read snapshot index"
        },
        {
          "index": 6,
          "from": "bausteinsicht.snapshot",
          "to": "architect",
          "label": "labeled snapshots, newest first",
          "type": "return"
        },
        {
          "index": 7,
          "from": "architect",
          "to": "bausteinsicht.cli.evolution",
          "label": "bausteinsicht snapshot diff pre-refactor ‑‑against current"
        },
        {
          "index": 8,
          "from": "bausteinsicht.cli.evolution",
          "to": "bausteinsicht.snapshot",
          "label": "load snapshot + current model, compute delta"
        },
        {
          "index": 9,
          "from": "bausteinsicht.snapshot",
          "to": "architect",
          "label": "added / removed / changed elements",
          "type": "return"
        },
        {
          "index": 10,
          "from": "architect",
          "to": "bausteinsicht.cli.evolution",
          "label": "bausteinsicht snapshot restore pre-refactor (destructive: overwrites model.jsonc)"
        },
        {
          "index": 11,
          "from": "bausteinsicht.cli.evolution",
          "to": "bausteinsicht.snapshot",
          "label": "delete: remove a labeled snapshot"
        }
      ]
    },
    {
      "key": "diff-and-changelog",
      "title": "As-Is/To-Be Diff and Changelog Generation",
      "description": "`diff` compares two model states (e.g. current vs. a target/to-be model); `changelog` walks git history calling `diff` at each relevant commit to build a human-readable architecture changelog.",
      "steps": [
        {
          "index": 1,
          "from": "architect",
          "to": "bausteinsicht.cli.evolution",
          "label": "bausteinsicht diff ‑‑to-be target.jsonc"
        },
        {
          "index": 2,
          "from": "bausteinsicht.cli.evolution",
          "to": "bausteinsicht.diff",
          "label": "compare(asIsModel, toBeModel)"
        },
        {
          "index": 3,
          "from": "bausteinsicht.diff",
          "to": "bausteinsicht.cli.evolution",
          "label": "added / removed / changed elements and relationships",
          "type": "return"
        },
        {
          "index": 4,
          "from": "architect",
          "to": "bausteinsicht.cli.evolution",
          "label": "bausteinsicht changelog ‑‑since v1.0.0"
        },
        {
          "index": 5,
          "from": "bausteinsicht.cli.evolution",
          "to": "bausteinsicht.changelog",
          "label": "for each relevant git ref: load model at that ref"
        },
        {
          "index": 6,
          "from": "bausteinsicht.changelog",
          "to": "bausteinsicht.diff",
          "label": "compare(modelAtRefN, modelAtRefN+1)"
        },
        {
          "index": 7,
          "from": "bausteinsicht.diff",
          "to": "bausteinsicht.changelog",
          "label": "delta per ref",
          "type": "return"
        },
        {
          "index": 8,
          "from": "bausteinsicht.changelog",
          "to": "architect",
          "label": "chronological architecture changelog (AsciiDoc/Markdown)",
          "type": "return"
        }
      ]
    },
    {
      "key": "export-family",
      "title": "Export: Diagrams, Tables, and Rendered Images",
      "description": "The three export commands read the model (and, for `export`, the synced draw.io document) and render it to an external format — the output-side counterpart to `import`. None of them write back to the model or draw.io.",
      "steps": [
        {
          "index": 1,
          "from": "architect",
          "to": "bausteinsicht.cli.export_cmds",
          "label": "bausteinsicht export-diagram ‑‑view containers ‑‑diagram-format plantuml"
        },
        {
          "index": 2,
          "from": "bausteinsicht.cli.export_cmds",
          "to": "bausteinsicht.diagram",
          "label": "render(view, format: plantuml|mermaid|dot|d2)"
        },
        {
          "index": 3,
          "from": "bausteinsicht.diagram",
          "to": "architect",
          "label": "text diagram source (stdout or file)",
          "type": "return"
        },
        {
          "index": 4,
          "from": "architect",
          "to": "bausteinsicht.cli.export_cmds",
          "label": "bausteinsicht export-table ‑‑view containers ‑‑format adoc"
        },
        {
          "index": 5,
          "from": "bausteinsicht.cli.export_cmds",
          "to": "bausteinsicht.table",
          "label": "render(view, format: adoc|markdown)"
        },
        {
          "index": 6,
          "from": "bausteinsicht.table",
          "to": "architect",
          "label": "table source (stdout or file)",
          "type": "return"
        },
        {
          "index": 7,
          "from": "architect",
          "to": "bausteinsicht.cli.export_cmds",
          "label": "bausteinsicht export ‑‑view containers"
        },
        {
          "index": 8,
          "from": "bausteinsicht.cli.export_cmds",
          "to": "bausteinsicht.export",
          "label": "read synced draw.io page, invoke headless draw.io CLI"
        },
        {
          "index": 9,
          "from": "bausteinsicht.export",
          "to": "bausteinsicht.drawio.document",
          "label": "read diagram page"
        },
        {
          "index": 10,
          "from": "bausteinsicht.export",
          "to": "architect",
          "label": "PNG / SVG file",
          "type": "return"
        }
      ]
    },
    {
      "key": "analysis-suite",
      "title": "Analysis: Health, Graph, Find, Lint",
      "description": "Read-only architecture-quality checks, all following the same shape as Stale Detection (load model, analyze, report) — shown together since the flow is structurally identical across all four.",
      "steps": [
        {
          "index": 1,
          "from": "architect",
          "to": "bausteinsicht.cli.analysis",
          "label": "bausteinsicht health"
        },
        {
          "index": 2,
          "from": "bausteinsicht.cli.analysis",
          "to": "bausteinsicht.health",
          "label": "score(model) across weighted categories"
        },
        {
          "index": 3,
          "from": "bausteinsicht.health",
          "to": "architect",
          "label": "health score + category breakdown",
          "type": "return"
        },
        {
          "index": 4,
          "from": "architect",
          "to": "bausteinsicht.cli.analysis",
          "label": "bausteinsicht graph ‑‑check-cycles"
        },
        {
          "index": 5,
          "from": "bausteinsicht.cli.analysis",
          "to": "bausteinsicht.graph",
          "label": "analyze(relationships): cycles, dependency depth, centrality"
        },
        {
          "index": 6,
          "from": "bausteinsicht.graph",
          "to": "architect",
          "label": "report (exit 1 if cycles found)",
          "type": "return"
        },
        {
          "index": 7,
          "from": "architect",
          "to": "bausteinsicht.cli.analysis",
          "label": "bausteinsicht find \"cache*\""
        },
        {
          "index": 8,
          "from": "bausteinsicht.cli.analysis",
          "to": "bausteinsicht.search",
          "label": "search(model, pattern) across elements/relationships/views"
        },
        {
          "index": 9,
          "from": "bausteinsicht.search",
          "to": "architect",
          "label": "matching elements",
          "type": "return"
        },
        {
          "index": 10,
          "from": "architect",
          "to": "bausteinsicht.cli.analysis",
          "label": "bausteinsicht lint"
        },
        {
          "index": 11,
          "from": "bausteinsicht.cli.analysis",
          "to": "bausteinsicht.constraints",
          "label": "evaluate(model, rules)"
        },
        {
          "index": 12,
          "from": "bausteinsicht.constraints",
          "to": "architect",
          "label": "violations (exit 1 if any)",
          "type": "return"
        }
      ]
    },
    {
      "key": "validate-standalone",
      "title": "Validate as a Standalone Gate",
      "description": "`validate` runs the same check other commands run internally before writing (see REPL Save, LLM-Driven Modification), but as its own entry point — typically in CI or a pre-commit hook, checked before any file is touched.",
      "steps": [
        {
          "index": 1,
          "from": "architect",
          "to": "bausteinsicht.cli.core",
          "label": "bausteinsicht validate (CI job or pre-commit hook)"
        },
        {
          "index": 2,
          "from": "bausteinsicht.cli.core",
          "to": "bausteinsicht.model.loader",
          "label": "Load(model.jsonc)"
        },
        {
          "index": 3,
          "from": "bausteinsicht.cli.core",
          "to": "bausteinsicht.model.validate",
          "label": "Validate(schema, references, constraints)"
        },
        {
          "index": 4,
          "from": "bausteinsicht.model.validate",
          "to": "bausteinsicht.cli.core",
          "label": "ok, or field-level errors",
          "type": "return"
        },
        {
          "index": 5,
          "from": "bausteinsicht.cli.core",
          "to": "architect",
          "label": "exit 0, or exit 1 with errors (blocks the commit/pipeline)",
          "type": "return"
        }
      ]
    },
    {
      "key": "tooling-commands",
      "title": "Tooling: Workspace, Layout, Generate-Template, Schema",
      "description": "Cross-cutting setup/maintenance commands, not part of the daily edit-sync loop: multi-model workspaces, auto-layout, template scaffolding, and JSON Schema regeneration for IDE support.",
      "steps": [
        {
          "index": 1,
          "from": "architect",
          "to": "bausteinsicht.cli.tooling",
          "label": "bausteinsicht workspace validate (multi-model project)"
        },
        {
          "index": 2,
          "from": "bausteinsicht.cli.tooling",
          "to": "bausteinsicht.workspace",
          "label": "load + merge multiple model files, cross-validate"
        },
        {
          "index": 3,
          "from": "bausteinsicht.workspace",
          "to": "architect",
          "label": "merged view, or cross-model conflicts",
          "type": "return"
        },
        {
          "index": 4,
          "from": "architect",
          "to": "bausteinsicht.cli.tooling",
          "label": "bausteinsicht layout ‑‑relayout"
        },
        {
          "index": 5,
          "from": "bausteinsicht.cli.tooling",
          "to": "bausteinsicht.layout",
          "label": "compute hierarchical auto-layout positions"
        },
        {
          "index": 6,
          "from": "bausteinsicht.layout",
          "to": "architect",
          "label": "repositioned elements written via next sync",
          "type": "return"
        },
        {
          "index": 7,
          "from": "architect",
          "to": "bausteinsicht.cli.tooling",
          "label": "bausteinsicht generate-template"
        },
        {
          "index": 8,
          "from": "bausteinsicht.cli.tooling",
          "to": "bausteinsicht.template",
          "label": "generate a draw.io template file from the specification's element kinds"
        },
        {
          "index": 9,
          "from": "bausteinsicht.template",
          "to": "architect",
          "label": "template.drawio (styled reference shapes per kind)",
          "type": "return"
        },
        {
          "index": 10,
          "from": "architect",
          "to": "bausteinsicht.cli.tooling",
          "label": "bausteinsicht schema generate"
        },
        {
          "index": 11,
          "from": "bausteinsicht.cli.tooling",
          "to": "bausteinsicht.schema",
          "label": "reflect Go model types into JSON Schema"
        },
        {
          "index": 12,
          "from": "bausteinsicht.schema",
          "to": "architect",
          "label": "bausteinsicht.schema.json (IDE autocompletion/validation)",
          "type": "return"
        }
      ]
    },
    {
      "key": "interactive-extras",
      "title": "Overlay and ADR",
      "description": "Two `interactive`-group commands outside the REPL itself: metric heatmap overlays on diagrams, and ADR (Architecture Decision Record) scaffolding.",
      "steps": [
        {
          "index": 1,
          "from": "architect",
          "to": "bausteinsicht.cli.interactive",
          "label": "bausteinsicht overlay apply ‑‑metric health"
        },
        {
          "index": 2,
          "from": "bausteinsicht.cli.interactive",
          "to": "bausteinsicht.overlay",
          "label": "apply(view, metric): color elements by score"
        },
        {
          "index": 3,
          "from": "bausteinsicht.overlay",
          "to": "bausteinsicht.drawio.document",
          "label": "write heatmap fill colors onto the diagram"
        },
        {
          "index": 4,
          "from": "bausteinsicht.overlay",
          "to": "architect",
          "label": "overlay applied (removable via overlay remove)",
          "type": "return"
        },
        {
          "index": 5,
          "from": "architect",
          "to": "bausteinsicht.cli.interactive",
          "label": "bausteinsicht adr new \"Use JSONC for the DSL\""
        },
        {
          "index": 6,
          "from": "bausteinsicht.cli.interactive",
          "to": "bausteinsicht.model.loader",
          "label": "scaffold ADR-NNN-Name.adoc from the Nygard template"
        },
        {
          "index": 7,
          "from": "bausteinsicht.cli.interactive",
          "to": "architect",
          "label": "new ADR file ready for editing",
          "type": "return"
        }
      ]
    }
  ]
}