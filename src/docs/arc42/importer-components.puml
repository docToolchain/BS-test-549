@startuml
!include <C4/C4_Component>

Container(bausteinsicht_cli, "CLI", "Go / Cobra", "Command-line interface providing validate, sync, export, and watch commands")
Container(bausteinsicht_model, "Model", "Go", "JSONC architecture model management — loading, validation, and mutation")
Container_Boundary(bausteinsicht_importer, "Importer") {
  Component(bausteinsicht_importer_likec4, "LikeC4", "Go", "LikeC4 DSL parsing and model conversion")
  Component(bausteinsicht_importer_structurizr, "Structurizr", "Go", "Structurizr DSL parsing and model conversion")
  Component(bausteinsicht_importer_xmi, "XMI", "Go", "XMI/Enterprise Architect parsing and model conversion. Buffers the whole file in memory and converts Windows-1252 to UTF-8 before parsing (peak RSS ~2x file size); a 200MB read cap is enforced.")
}

Rel(bausteinsicht_cli, bausteinsicht_model, "loads/saves JSONC")
Rel(bausteinsicht_cli, bausteinsicht_importer, "imports models")
Rel(bausteinsicht_importer, bausteinsicht_model, "populates model")
Rel(bausteinsicht_importer_structurizr, bausteinsicht_model, "creates elements")
Rel(bausteinsicht_importer_likec4, bausteinsicht_model, "creates elements")
@enduml
